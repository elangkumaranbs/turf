rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ──────────────────────────────────────────────────────────────
    // Helper Functions
    // ──────────────────────────────────────────────────────────────
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Get user data from database
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Check if user is super admin
    function isSuperAdmin() {
      return isAuthenticated() && 
             (getUserData().role == 'super_admin' || 
              request.auth.token.email == 'gamedenoffiz@gmail.com');
    }
    
    // Check if user is turf admin (owner)
    function isTurfAdmin() {
      return isAuthenticated() && getUserData().role == 'turf_admin';
    }
    
    // Check if user is turf admin or super admin
    function isAdminOrSuper() {
      return isSuperAdmin() || isTurfAdmin();
    }
    
    // Check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // ──────────────────────────────────────────────────────────────
    // USERS Collection
    // ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Users can read their own doc; admins can read any user (for customer name lookups)
      allow read: if isOwner(userId) || isAdminOrSuper();
      
      // Super admin can read all users
      allow list: if isSuperAdmin();
      
      // Users can create their own document on signup
      allow create: if isOwner(userId);
      
      // Users can update their own profile (except role)
      allow update: if isOwner(userId) && 
                       (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
      
      // Super admin can update any user (including role changes)
      allow update: if isSuperAdmin();
      
      // Super admin can delete users
      allow delete: if isSuperAdmin();
    }
    
    // ──────────────────────────────────────────────────────────────
    // TURFS Collection
    // ──────────────────────────────────────────────────────────────
    match /turfs/{turfId} {
      // Everyone can read turfs (public listings)
      allow read: if true;
      
      // Everyone can list turfs
      allow list: if true;
      
      // Turf admin can create their own turfs
      allow create: if isAdminOrSuper() && 
                       (isSuperAdmin() || request.resource.data.adminId == request.auth.uid);
      
      // Owner can update their own turfs
      allow update: if isOwner(resource.data.adminId) || isSuperAdmin();
      
      // Allow any user to update ONLY the rating fields when submitting a review
      allow update: if isAuthenticated() && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['averageRating', 'reviewCount']);
      
      // Owner or super admin can delete
      allow delete: if isOwner(resource.data.adminId) || isSuperAdmin();
    }
    
    // ──────────────────────────────────────────────────────────────
    // BOOKINGS Collection
    // ──────────────────────────────────────────────────────────────
    match /bookings/{bookingId} {
      // User can read their own bookings
      allow read: if isOwner(resource.data.userId) || isSuperAdmin();
      
      // Turf admin can read bookings for their turfs
      allow read: if isAdminOrSuper() && 
                     get(/databases/$(database)/documents/turfs/$(resource.data.turfId)).data.adminId == request.auth.uid;
      
      // List bookings: users see their own, admins see their turfs', super admin sees all
      allow list: if isAuthenticated();
      
      // Authenticated users can create bookings (online)
      allow create: if isAuthenticated() && 
                       request.resource.data.userId == request.auth.uid;
      
      // Turf admin can create offline blocks for their own turfs
      allow create: if isAdminOrSuper() &&
                       get(/databases/$(database)/documents/turfs/$(request.resource.data.turfId)).data.adminId == request.auth.uid;
      
      // User can update their own bookings (e.g., cancel)
      allow update: if isOwner(resource.data.userId) || isSuperAdmin();
      
      // Turf admin can update bookings for their turfs
      allow update: if isAdminOrSuper() && 
                       get(/databases/$(database)/documents/turfs/$(resource.data.turfId)).data.adminId == request.auth.uid;
      
      // Delete: user, turf owner, or super admin
      allow delete: if isOwner(resource.data.userId) || isSuperAdmin();
      allow delete: if isAdminOrSuper() && 
                       get(/databases/$(database)/documents/turfs/$(resource.data.turfId)).data.adminId == request.auth.uid;
    }
    
    // ──────────────────────────────────────────────────────────────
    // LOCATIONS Collection
    // ──────────────────────────────────────────────────────────────
    match /locations/{locationId} {
      // Everyone can read locations (needed for the public search page)
      allow read: if true;
      allow list: if true;
      
      // Only super admin can manage locations
      allow write: if isSuperAdmin();
    }
    
    // ──────────────────────────────────────────────────────────────
    // PENDING ORDERS Collection (slot locking during payment)
    // ──────────────────────────────────────────────────────────────
    match /pending_orders/{orderId} {
      // Everyone can read pending orders (needed for slot availability on public turf pages)
      allow read: if true;
      allow list: if true;
      
      // Authenticated users can create pending orders
      allow create: if isAuthenticated() && 
                       request.resource.data.userId == request.auth.uid;
      
      // Owner can delete their own pending order, or super admin
      allow delete: if isOwner(resource.data.userId) || isSuperAdmin();
      
      // No updates needed — pending orders are created and deleted only
      allow update: if false;
    }
    
    // ──────────────────────────────────────────────────────────────
    // REVIEWS Collection
    // ──────────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      // Everyone can read and list reviews
      allow read, list: if true;
      
      // Authenticated users can create reviews
      allow create: if isAuthenticated() && 
                       request.resource.data.userId == request.auth.uid;
                       
      // Users can update their own reviews
      allow update: if isOwner(resource.data.userId);
      
      // Users can delete their own reviews, or super admin can delete any
      allow delete: if isOwner(resource.data.userId) || isSuperAdmin();
    }
    
    // ──────────────────────────────────────────────────────────────
    // Default: Deny all other collections
    // ──────────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
